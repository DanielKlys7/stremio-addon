# Konfiguracja addonu (klucze TorBox/OpenAI) NIE jest już w .env.
# Każdy użytkownik generuje swój prywatny link instalacyjny na stronie /configure,
# a klucze są zakodowane w samym URL-u. Hostujesz raz, udostępniasz wielu osobom.

# Jedyna opcjonalna zmienna dla lokalnego uruchomienia:
# Port serwera (domyślnie 7000).
# PORT=7000
