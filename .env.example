# Skopiuj ten plik do .env i uzupełnij. .env jest w .gitignore.

# Sekret chroniący addon — wpisujesz go w URL instalacyjnym w Stremio (wymagany).
# Wygeneruj losowy, np.:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADDON_SECRET=

# Klucz TorBox API (wymagany)
TORBOX_API_KEY=

# Klucz OpenAI (wymagany do generowania ładnych nazw; bez niego działa fallback)
OPENAI_API_KEY=

# Model OpenAI (opcjonalnie, domyślnie gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Tag-flaga oznaczający, że torrent ma już wygenerowaną nazwę (opcjonalnie)
# TORBOX_CHANGED_KEYWORD=openai-named

# Port serwera (opcjonalnie, domyślnie 7000)
# PORT=7000
